---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/format';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, readingTime } = post.data;
const base = import.meta.env.BASE_URL;
---

<a class="item" href={`${base}blog/${post.id}/`}>
  <div class="pdate">{formatDate(pubDate)}</div>
  <div class="ptitle">{title}</div>
  <div class="pex">{description}</div>
  <div class="pmeta">
    {tags.map((t) => <span class="chip">{t}</span>)}
    {readingTime && <span class="chip">{readingTime}</span>}
  </div>
</a>
